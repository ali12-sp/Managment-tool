# Database
DATABASE_URL=postgresql://user:password@localhost:5432/opsboard

# Server
PORT=4000

# JWT Secrets
JWT_ACCESS_SECRET=your-super-secret-key-here-at-least-30-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-30-chars

# Token Expiry
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Stripe (optional - for billing feature)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App URL (for Stripe redirects)
APP_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database Limits (for FREE tier)
FREE_TASK_LIMIT=50
